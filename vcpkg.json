{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "dosbox-automation",
  "description": "DOS emulator with HTTP REST API and Lua scripting for automated game installation and testing.",
  "version": "0.84.0",
  "dependencies": [
    "asio",
    "gtest",
    "iir1",
    "libjpeg-turbo",
    "libmt32emu",
    "libpng",
    "opusfile",
    "fluidsynth",
    {
      "name": "sdl2",
      "platform": "linux",
      "features": ["alsa", "dbus", "ibus", "wayland", "x11"]
    }, {
      "name": "sdl2",
      "platform": "!linux"
    },
    "sdl2-image",
    "speexdsp",
    "lua",
    "sol2",
    "zlib",
    {
      "name": "pkgconf",
      "host": true
    }
  ],
  "builtin-baseline": "6283825b81bb60f952af1d0703638df1de611243"
}
