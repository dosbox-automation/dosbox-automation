{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "dosbox-automation",
  "description": "DOS emulator with HTTP REST API and Lua scripting for automated game installation and testing.",
  "version": "0.84.0",
  "dependencies": [
    "asio",
    "gtest",
    "iir1",
    "libjpeg-turbo",
    "libmt32emu",
    "libpng",
    "opusfile",
    "fluidsynth",
    {
      "name": "sdl3",
      "platform": "linux",
      "default-features": false,
      "features": [
        "alsa",
        "vulkan",
        "wayland",
        "x11"
      ]
    },
    {
      "name": "sdl3",
      "platform": "!linux"
    },
    "sdl3-image",
    "speexdsp",
    "lua",
    "sol2",
    "zlib",
    {
      "name": "pkgconf",
      "host": true
    }
  ],
  "builtin-baseline": "8defa4b8bc4c35071c678e87a0e140dd433489bb"
}
