set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
DOSBOX_BIN="${DOSBOX_BIN:-$PROJECT_DIR/build/debug-linux/dosbox}"
TOKEN="deadbeef00112233445566778899aabbccddeeff00112233445566778899aabb"
PORT="${DOSBOX_PORT:-18080}"

usage() {
    echo "Usage: dosboxapictl <command> [args]"
    echo ""
    echo "  start <hd_dir> <source_dir> [extra -c args...]"
    echo "      Start DOSBox visible with C: and A: mounted."
    echo ""
    echo "  screen"
    echo "      Print current screen text."
    echo ""
    echo "  type <text>"
    echo "      Type text into DOSBox (appends Enter)."
    echo ""
    echo "  key <name>"
    echo "      Press and release a key (e.g. enter, down, escape)."
    echo ""
    echo "  stop"
    echo "      Shutdown running DOSBox instance."
    echo ""
    echo "  token"
    echo "      Print the API token."
    exit 1
}

api() {
    curl -s -H "Authorization: Bearer $TOKEN" "http://127.0.0.1:$PORT$1" "${@:2}"
}

cmd_start() {
    local hd_dir="$1"; shift
    local source_dir="$1"; shift

    hd_dir="$(realpath "$hd_dir")"
    source_dir="$(realpath "$source_dir")"

    mkdir -p "$hd_dir"

    local extra_c=()
    while [[ $# -gt 0 ]]; do
        extra_c+=(-c "$1")
        shift
    done

    local resource_dir
    resource_dir="$(dirname "$DOSBOX_BIN")/resources"
    resource_dir="$(realpath "$resource_dir" 2>/dev/null || echo "$resource_dir")"

    local config_dir="$hd_dir/.config/dosbox-automation"
    mkdir -p "$config_dir"
    cat > "$config_dir/dosbox-automation.conf" << CONF
[webserver]
mount_allowed_bases = $resource_dir;$hd_dir;$source_dir
mount_allowed_image_roots = $hd_dir;$source_dir
CONF

    export DOSBOX_API_TOKEN="$TOKEN"
    export HOME="$hd_dir"

    DOSBOX_VISIBLE=1 "$DOSBOX_BIN" \
        --set "webserver_enabled=true" \
        --set "webserver_port=$PORT" \
        --set "cpu_cycles=12000" \
        --set "joysticktype=none" \
        -c "mount C \"$hd_dir\"" \
        -c "mount A \"$source_dir\"" \
        -c "C:" \
        "${extra_c[@]}" \
        2>/dev/null &

    echo "DOSBox PID: $!"
    echo "Waiting for API..."

    for i in $(seq 1 20); do
        if api /api/v1/status >/dev/null 2>&1; then
            echo "API ready on port $PORT"
            return 0
        fi
        sleep 0.5
    done
    echo "API did not come up"
    return 1
}

cmd_screen() {
    api /api/v1/video/text | python3 -c "
import sys, json
d = json.load(sys.stdin)
text = d.get('text', '')
for line in text.splitlines():
    s = line.rstrip()
    if s:
        print(s)
"
}

cmd_type() {
    local text="$1"
    api /api/v1/script/load \
        -X POST \
        -H "Content-Type: text/plain" \
        -d "dosbox.type(\"${text}\\n\")" >/dev/null
    api /api/v1/script/start -X POST >/dev/null
    sleep 1
}

cmd_key() {
    local name="$1"
    api /api/v1/script/load \
        -X POST \
        -H "Content-Type: text/plain" \
        -d "dosbox.key(\"KBD_${name}\", true)
dosbox.wait_frames(8)
dosbox.key(\"KBD_${name}\", false)" >/dev/null
    api /api/v1/script/start -X POST >/dev/null
    sleep 0.5
}

cmd_stop() {
    api /api/v1/dosbox/shutdown -X POST >/dev/null 2>&1
    echo "Shutdown sent"
}

cmd_token() {
    echo "$TOKEN"
}

[[ $# -lt 1 ]] && usage

case "$1" in
    start)  shift; cmd_start "$@" ;;
    screen) cmd_screen ;;
    type)   shift; cmd_type "$*" ;;
    key)    shift; cmd_key "$1" ;;
    stop)   cmd_stop ;;
    token)  cmd_token ;;
    *)      usage ;;
esac
