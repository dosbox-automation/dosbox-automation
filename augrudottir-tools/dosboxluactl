set -euo pipefail

TOKEN="${DOSBOX_API_TOKEN:-deadbeef00112233445566778899aabbccddeeff00112233445566778899aabb}"
PORT="${DOSBOX_PORT:-18080}"

usage() {
    echo "Usage: dosboxluactl <command> [args]"
    echo ""
    echo "  run <lua_code>"
    echo "      Load and run a Lua snippet."
    echo ""
    echo "  file <path.lua>"
    echo "      Load and run a Lua file."
    echo ""
    echo "  status"
    echo "      Print script status and output."
    echo ""
    echo "  stop"
    echo "      Stop running script."
    echo ""
    echo "  screen"
    echo "      Print screen text."
    echo ""
    echo "  frame <output.png>"
    echo "      Capture frame to file."
    echo ""
    echo "  wait <text> [timeout_frames]"
    echo "      Wait for text on screen (default 1800 frames)."
    exit 1
}

api() {
    curl -s -H "Authorization: Bearer $TOKEN" "http://127.0.0.1:$PORT$1" "${@:2}"
}

cmd_run() {
    local code="$1"
    api /api/v1/script/load \
        -X POST -H "Content-Type: text/plain" \
        -d "$code" || return 1
    echo ""
    api /api/v1/script/start -X POST
    echo ""
}

cmd_file() {
    local path="$1"
    api /api/v1/script/load \
        -X POST -H "Content-Type: text/plain" \
        --data-binary "@$path" || return 1
    echo ""
    api /api/v1/script/start -X POST
    echo ""
}

cmd_status() {
    api /api/v1/script/status | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"state: {d.get('state','?')}\")
if d.get('error'):
    print(f\"error: {d['error']}\")
for k, v in sorted(d.get('output', {}).items()):
    print(f\"  {k} = {v}\")
"
}

cmd_stop() {
    api /api/v1/script/stop -X POST
    echo ""
}

cmd_screen() {
    api /api/v1/video/text | python3 -c "
import sys, json
d = json.load(sys.stdin)
for line in d.get('text', '').splitlines():
    s = line.rstrip()
    if s:
        print(s)
"
}

cmd_frame() {
    local out="${1:-frame.png}"
    curl -s -H "Authorization: Bearer $TOKEN" \
        "http://127.0.0.1:$PORT/api/v1/video/frame?format=png" \
        -o "$out"
    echo "Saved: $out"
}

cmd_wait() {
    local text="$1"
    local timeout="${2:-1800}"
    cmd_run "dosbox.wait_for_text(\"$text\", $timeout)"
}

[[ $# -lt 1 ]] && usage

case "$1" in
    run)    shift; cmd_run "$*" ;;
    file)   shift; cmd_file "$1" ;;
    status) cmd_status ;;
    stop)   cmd_stop ;;
    screen) cmd_screen ;;
    frame)  shift; cmd_frame "${1:-frame.png}" ;;
    wait)   shift; cmd_wait "$@" ;;
    *)      usage ;;
esac
