
#include "winresrc.h"

// icon resource
DOSBOX_ICO ICON "@CMAKE_SOURCE_DIR@/resources/icons/windows/dosbox-automation.ico"

// version resource
VS_VERSION_INFO VERSIONINFO
 FILEVERSION @CMAKE_PROJECT_VERSION_MAJOR@,@CMAKE_PROJECT_VERSION_MINOR@,@CMAKE_PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @CMAKE_PROJECT_VERSION_MAJOR@,@CMAKE_PROJECT_VERSION_MINOR@,@CMAKE_PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "Comments", "(C) 2026 dosbox-automation contributors, published under GNU GPL"
            VALUE "CompanyName", "dosbox-automation"
            VALUE "FileDescription", "dosbox-automation DOS Emulator"
            VALUE "FileVersion", "@CMAKE_PROJECT_VERSION_MAJOR@, @CMAKE_PROJECT_VERSION_MINOR@, @CMAKE_PROJECT_VERSION_PATCH@, 0"
            VALUE "InternalName", "dosbox-automation"
            VALUE "LegalCopyright", "Copyright (C) 2026 dosbox-automation contributors"
            VALUE "OriginalFilename", "dosbox.exe"
            VALUE "ProductName", "dosbox-automation"
            VALUE "ProductVersion", "@CMAKE_PROJECT_VERSION_MAJOR@, @CMAKE_PROJECT_VERSION_MINOR@, @CMAKE_PROJECT_VERSION_PATCH@, 0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
