Newer glibc/kernel headers define EFSBADCRC and EFSCORRUPTED as aliases
of existing errno values, so the generated errno-to-name.h contains
duplicate designated initializers and -Werror=override-init breaks the
build. Demote it to the plain warning.

diff --git a/meson.build b/meson.build
index 1111111..2222222 100644
--- a/meson.build
+++ b/meson.build
@@ -379,7 +379,7 @@ possible_common_cc_flags = [
         '-Werror=missing-declarations',
         '-Werror=missing-prototypes',
         '-Werror=overflow',
-        '-Werror=override-init',
+        '-Wno-override-init',
         '-Werror=return-type',
         '-Werror=shift-count-overflow',
         '-Werror=shift-overflow=2',
